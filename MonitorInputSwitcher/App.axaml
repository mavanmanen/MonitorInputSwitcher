<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:MonitorInputSwitcher.ViewModels"
             x:Class="MonitorInputSwitcher.App"
             x:DataType="{x:Type viewModels:ApplicationViewModel}"
             RequestedThemeVariant="Default">
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Design.DataContext>
        <viewModels:ApplicationViewModel />
    </Design.DataContext>

    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="/Assets/avalonia-logo.ico"
                      ToolTipText="Avalonia Tray Icon ToolTip">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="{Binding DesktopHeader}" Command="{Binding SwitchInputCommand}" CommandParameter="{Binding DesktopValue}" />
                        <NativeMenuItem Header="{Binding LaptopHeader}" Command="{Binding SwitchInputCommand}" CommandParameter="{Binding LaptopValue}" />
                        <NativeMenuItem Header="Quit" Command="{Binding QuitCommand}"/>
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
</Application>